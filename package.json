{
  "name": "ml-teaching-platform",
  "private": true,
  "version": "2.5.3",
  "type": "module",
  "scripts": {
    "sync:pyodide": "node scripts/sync-pyodide-assets.mjs",
    "postinstall": "npm run sync:pyodide",
    "dev": "npm run sync:pyodide && concurrently -k -n web,api -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "npm run sync:pyodide && tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "vite build -- --report",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "pyodide": "^0.29.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
